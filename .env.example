# Copy this to .env for local development (never commit .env)
# On Zeabur, set these in the Environment Variables dashboard

# From @BotFather → /newbot
TELEGRAM_TOKEN=your_bot_token_here

# Your channel or group chat ID (e.g. -1001234567890)
# To find it: send a message to the chat, then call:
# https://api.telegram.org/bot<TOKEN>/getUpdates
# and look for "chat": {"id": ...}
TARGET_CHAT_ID=your_chat_id_here

# From console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Set to 1 to include vulgar Singlish words (knnccb, cb, knn etc) in the daily rotation
# Default is 0 (clean pool only)
ALLOW_NSFW=0
